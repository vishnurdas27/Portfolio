# ---- Server ----
PORT=5000
CLIENT_URL=http://localhost:5173

# ---- Database (MongoDB Atlas) ----
# Paste your Atlas connection string here. Keep the /portfolio database name.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Admin account (created/updated by `npm run seed`) ----
ADMIN_NAME=Vishnu R Das
ADMIN_EMAIL=admin@vishnurdas.dev
ADMIN_PASSWORD=ChangeMe123!

# ---- Optional: contact-form email notifications ----
# Leave SMTP_* blank to disable email (messages are still saved to the DB).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_TO=
